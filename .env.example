# Copy to .env.local and fill in when ready. Every value here is optional —
# the site runs entirely on placeholder data until these are set.

# --- Sanity CMS (src/lib/cms/sanity, /studio) -------------------------------
# Create a free project at https://www.sanity.io/manage (no code, no CLI),
# then set the project ID it gives you:
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
# Only needed for authenticated/preview reads of unpublished drafts:
SANITY_API_TOKEN=
# Set up in Sanity's manage UI under API > Webhooks, pointing at
# /api/revalidate, so publishing an article goes live within seconds
# instead of waiting for the normal cache window. See docs/CMS_GUIDE.md.
SANITY_REVALIDATE_SECRET=

# --- API-Football (src/lib/sports-api/api-football) ------------------------
# Get a key at https://www.api-football.com (free tier: 100 requests/day)
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
# Real Madrid's team ID and LaLiga's league ID on API-Football:
API_FOOTBALL_TEAM_ID=541
API_FOOTBALL_LEAGUE_ID=140
# UEFA Champions League's league ID (defined for future use; not
# currently used by any fetch — the site only pulls LaLiga data today):
API_FOOTBALL_CHAMPIONS_LEAGUE_ID=2

# --- SportsAPI Pro (src/lib/football/providers/sportsApiPro.ts) ------------
# A dormant alternate provider. Get a key at https://sportsapipro.com/register
# — one key works across all their sports APIs. Team/competition IDs are
# resolved automatically via their /search endpoint and cached, not
# hardcoded, since this is a new provider with no previously-known ID
# mapping.
SPORTSAPIPRO_API_KEY=
SPORTSAPIPRO_BASE_URL=https://api.sportsapipro.com/v2

# --- football-data.org (src/lib/sports-api/football-data) ------------------
# The active football data provider — fixtures, results, the live match
# centre, and standings. Get a free key at
# https://www.football-data.org/client/register (just an email, instant).
# Chosen over API-Football specifically because its free tier includes
# current-season data; API-Football's free tier only covers 2022-2024.
# Free tier is rate-limited to 10 requests/minute across the whole account.
FOOTBALL_DATA_API_KEY=
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
# Real Madrid's team ID and La Liga's / Champions League's competition
# codes on football-data.org:
FOOTBALL_DATA_TEAM_ID=86
FOOTBALL_DATA_LALIGA_CODE=PD
FOOTBALL_DATA_UCL_CODE=CL

# --- Site -------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://themadridzone.com
